# Slack 앱 (https://api.slack.com/apps)
# Event Subscriptions → Request URL: …/api/slack
# Interactivity & Shortcuts → Request URL: …/api/slack/interactive (모달·버튼·체크리스트 필수)
# Slash Commands → /check Request URL: …/api/slack/slash (Jira와 무관)
SLACK_SIGNING_SECRET=
# /check 면션 전용 줄의 @핸들 → user id 변환에 users:read 가 필요합니다 (users.lookupByUsername)
SLACK_BOT_TOKEN=xoxb-
# 트리거 이모지 이름(콜론 없이). 커스템이면 jira_add 형태
SLACK_REACTION_NAME=jira_add

# Jira Cloud — https://id.atlassian.com/manage-profile/security/api-tokens
# 호스트만 (https·끝의 / 없이). 잘못 예: your.atlassian.net/ → //rest/ 이중 슬래시 오류
JIRA_HOST=your-domain.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ
JIRA_ISSUE_TYPE=Task
# 선택: Jira Software 보드 ID — 설정 시 모달에 활성·예정 스프린트 목록 표시
# (보드 URL 또는 "애자일" 보드 화면에서 ID 확인)
# JIRA_BOARD_ID=123
# 선택: 이슈 링크에 쓸 베이스 (기본 https://JIRA_HOST/browse)
# JIRA_BROWSE_URL=https://your-domain.atlassian.net/browse
